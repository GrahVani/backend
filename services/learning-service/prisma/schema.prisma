generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// CURRICULUM HIERARCHY
// Tier -> Module -> Chapter -> Lesson
// ============================================================

model Tier {
  id          String   @id @default(cuid())
  number      Int      @unique
  title       String
  description String?
  status      TierStatus @default(ACTIVE)
  modules     Module[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum TierStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

model Module {
  id          String    @id @default(cuid())
  tierId      String
  number      Int
  slug        String    @unique
  title       String
  description String?
  overviewMarkdown  String?  @db.Text  // Full 00-module-overview.md content
  learningObjectives String[]          // Extracted from overview
  status      ModuleStatus @default(DRAFT)
  sequenceOrder Int     @default(0)
  tier        Tier      @relation(fields: [tierId], references: [id])
  chapters    Chapter[]
  moduleProgress ModuleProgress[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tierId, number])
  @@index([slug])
}

enum ModuleStatus {
  DRAFT
  TECHNICAL_AUDIT
  PEDAGOGICAL_AUDIT
  PUBLISHED
  REVISION_NEEDED
}

model Chapter {
  id          String   @id @default(cuid())
  moduleId    String
  number      Int
  slug        String
  title       String
  description String?
  overviewMarkdown  String?  @db.Text  // Full 00-chapter-overview.md content
  learningObjectives String[]          // Extracted from overview
  status      ChapterStatus @default(DRAFT)
  sequenceOrder Int    @default(0)
  module      Module   @relation(fields: [moduleId], references: [id])
  lessons     Lesson[]
  chapterProgress ChapterProgress[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([moduleId, number])
  @@index([slug])
}

enum ChapterStatus {
  DRAFT
  PUBLISHED
}

model Lesson {
  id                   String          @id @default(cuid())
  slug                 String          @unique
  chapterId            String

  // Placement (denormalized for quick lookups without joins)
  tier                 Int
  module               Int
  chapter              Int
  sequence             Int

  // Content
  title                String
  titleDevanagari      String?
  subtitle             String?

  // Pedagogy
  lessonType           LessonType      @default(CONCEPTUAL)
  bloomLevels          String[]
  targetMinutesReading Int             @default(15)
  targetMinutesTotal   Int             @default(30)

  // Stream coverage
  streams              String[]
  streamNeutrality     Boolean         @default(true)

  // Dependencies
  prerequisites        String[]        // array of lesson slugs
  postrequisites       String[]        // computed array of lesson slugs

  // Learning outcomes
  learningOutcomes     String[]

  // Sources
  primarySources       Json?           // [{ ref, note }]
  modernSources        Json?           // [{ ref, note }]

  // Interactive component
  interactiveEnabled   Boolean         @default(false)
  interactiveType      String?
  interactiveSpecFile  String?          // Path (legacy)
  interactiveSpec      String?  @db.Text // Full spec content (new)
  interactiveFallback  String?  @db.Text // Fallback text when component fails/offline
  interactiveEndpoints String[]

  // Assessment
  mcqCount             Int             @default(0)

  // Body (12-section markdown)
  bodyMarkdown         String          @db.Text

  // Audit & versioning
  authoringStatus      AuthoringStatus @default(DRAFT)
  version              String          @default("1.0")
  authors              String[]
  technicalReviewer    String?
  pedagogicalReviewer  String?

  // Accessibility
  hasDevanagari        Boolean         @default(false)
  hasDiagrams          Boolean         @default(false)
  hasAudio             Boolean         @default(false)
  estimatedReadingGrade Int?

  // Content audit
  lastUpdated          DateTime?

  // Sectioned content (for AI search & granular access)
  commonMistakes    Json?             // Extracted from §8
  slokaBlocks       Json?             // Extracted from §5
  testYourself      String?  @db.Text // Extracted from §10
  summary90Seconds  String?  @db.Text // Extracted from §11

  // Relations
  chapterRef           Chapter         @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  lessonProgress       LessonProgress[]
  quizAttempts         QuizAttempt[]
  spacedRepetitionCards SpacedRepetitionCard[]
  mcqBank              McqBank?
  lessonSections       LessonSection[]

  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([tier, module, chapter, sequence])
  @@index([slug])
  @@index([authoringStatus])
}

// ── MCQ Bank (ingested from assessment-bank/*.json) ──
model McqBank {
  id          String   @id @default(cuid())
  lessonId    String   @unique
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  questions   Json     // Full array of MCQ question objects
  schemaVersion String @default("1.0")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("mcq_banks")
}

// ── Lesson Sections (§1–§12 parsed for AI search) ──
model LessonSection {
  id            String   @id @default(cuid())
  lessonId      String
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  sectionNumber Int
  sectionTitle  String
  sectionType   String   // hook, prerequisites, outcomes, body, sloka, worked_example, interactive, common_mistake, remember, test_yourself, summary, citations
  content       String   @db.Text

  // AI vector search (populated later, nullable for now)
  // embedding     Unsupported("vector(1536)")?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([lessonId, sectionNumber])
  @@index([lessonId])
  @@index([sectionType])
  @@map("lesson_sections")
}

enum LessonType {
  CONCEPTUAL
  CALCULATIVE
  INTERPRETIVE
  SYNTHESIS
  PROSE_ESSAY
  CASE_STUDY
}

enum AuthoringStatus {
  DRAFT
  TECHNICAL_AUDIT
  PEDAGOGICAL_AUDIT
  PUBLISHED
  REVISION_NEEDED
}

// ============================================================
// USER PROGRESS & MASTERY
// ============================================================

model LessonProgress {
  id                       String    @id @default(cuid())
  userId                   String
  lessonId                 String
  moduleId                 String
  status                   ProgressStatus @default(LOCKED)
  completionPercentage     Int       @default(0)
  score                    Int       @default(0)
  questionsAttempted       Int       @default(0)
  questionsCorrect         Int       @default(0)
  questionsCorrectFirstTry Int       @default(0)
  pointsEarned             Int       @default(0)
  startedAt                DateTime?
  completedAt              DateTime?
  lastAttemptedAt          DateTime?
  sectionsViewedJson       Json?

  lesson                   Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([status])
}

enum ProgressStatus {
  LOCKED
  AVAILABLE
  IN_PROGRESS
  COMPLETED
  MASTERED
}

model ChapterProgress {
  id                 String    @id @default(cuid())
  userId             String
  chapterId          String
  status             ProgressStatus @default(LOCKED)
  completionPercentage Int     @default(0)
  averageLessonScore Int       @default(0)
  chapterCheckScore  Int       @default(0)
  pointsEarned       Int       @default(0)
  startedAt          DateTime?
  completedAt        DateTime?
  progressPercentage Int       @default(0)

  chapter            Chapter   @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
}

model ModuleProgress {
  id                   String    @id @default(cuid())
  userId               String
  moduleId             String
  status               ProgressStatus @default(LOCKED)
  averageLessonScore   Int       @default(0)
  finalAssessmentScore Int       @default(0)
  prerequisiteModuleId String?
  prerequisiteMet      Boolean   @default(false)
  pointsEarned         Int       @default(0)
  startedAt            DateTime?
  completedAt          DateTime?
  progressPercentage   Int       @default(0)

  module               Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
}

model QuizAttempt {
  id               String    @id @default(cuid())
  userId           String
  lessonId         String
  moduleId         String
  score            Int       @default(0)
  totalQuestions   Int
  correctAnswers   Int       @default(0)
  answersJson      Json      @default("{}")
  startedAt        DateTime
  completedAt      DateTime?
  timeSpentSeconds Int?
  pointsEarned     Int       @default(0)
  createdAt        DateTime  @default(now())

  lesson           Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@index([createdAt])
}

// ============================================================
// GAMIFICATION
// ============================================================

model UserLearningProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  skillScore             Int       @default(0)
  currentTier            Int       @default(1)
  currentLevel           String    @default("LEVEL_1")
  currentStreak          Int       @default(0)
  longestStreak          Int       @default(0)
  lastActivityDate       DateTime?
  totalPoints            Int       @default(0)
  totalQuestionsAnswered Int       @default(0)
  totalCorrectAnswers    Int       @default(0)
  totalLessonsCompleted  Int       @default(0)
  totalModulesCompleted  Int       @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model PointsTransaction {
  id              String   @id @default(cuid())
  userId          String
  amount          Int
  transactionType String
  referenceId     String?
  referenceType   String?
  balanceAfter    Int
  description     String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([transactionType])
}

model BadgeDefinition {
  id               String      @id @default(cuid())
  badgeCode        String      @unique
  name             String
  description      String
  iconUrl          String?
  rarity           String?
  unlockConditions Json        @default("{}")
  pointsReward     Int         @default(0)
  createdAt        DateTime    @default(now())
  userBadges       UserBadge[]
}

model UserBadge {
  id       String          @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime        @default(now())
  badge    BadgeDefinition @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model DailyActivity {
  id                 String   @id @default(cuid())
  userId             String
  activityDate       DateTime
  hadLogin           Boolean  @default(false)
  hadLessonActivity  Boolean  @default(false)
  hadPanchangaCheck  Boolean  @default(false)
  hadPeerInteraction Boolean  @default(false)
  pointsEarnedToday  Int      @default(0)

  @@unique([userId, activityDate])
  @@index([userId])
}

model LeaderboardSnapshot {
  id           String    @id @default(cuid())
  periodType   String
  periodStart  DateTime?
  periodEnd    DateTime?
  userId       String
  rankPosition Int
  totalPoints  Int
  computedAt   DateTime  @default(now())

  @@unique([periodType, periodStart, userId])
  @@index([userId])
}

// ============================================================
// BIBLIOGRAPHY (03-source-citation-standard.md §12)
// ============================================================

model BibliographyEntry {
  id              String    @id @default(cuid())
  refKey          String    @unique // e.g., "BPHS", "Santhanam-1996"
  entryType       BibEntryType // PRIMARY or MODERN
  title           String
  author          String?
  year            String?
  publisher       String?
  isbn            String?
  stream          String?
  notes           String?   @db.Text
  citedInModules  String[]  // module slugs
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum BibEntryType {
  PRIMARY
  MODERN
}

// ============================================================
// INTERACTIVE COMPONENTS (05-interactive-component-taxonomy.md)
// ============================================================

model InteractiveComponent {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  family          String    // Manipulator, Visualiser, Calculator, Navigator, Comparator, Synthesiser, Rectifier, Quizzer
  tierCompatibility String  // T1, T2, Both
  status          ComponentStatus @default(SPEC_ONLY)
  specFile        String?
  astroEngineEndpoints String[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  events          InteractiveEvent[]
}

enum ComponentStatus {
  SPEC_ONLY
  IMPLEMENTED
  PUBLISHED
}

model InteractiveEvent {
  id              String    @id @default(cuid())
  userId          String
  componentId     String
  lessonId        String?
  
  eventType       String    // open, close, interaction, input_change
  eventData       Json?     // { inputName, inputValue, durationSeconds }
  
  createdAt       DateTime  @default(now())
  
  component       InteractiveComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  
  @@index([userId, componentId])
  @@index([lessonId])
  @@index([createdAt])
}

// ============================================================
// SPACED REPETITION (01-pedagogical-framework.md §5.3)
// ============================================================

model SpacedRepetitionCard {
  id              String    @id @default(cuid())
  userId          String
  lessonId        String
  
  // Card content
  front           String    @db.Text
  back            String    @db.Text
  sourceType      SRSourceType // MCQ, CALL_OUT, GLOSSARY
  sourceId        String?   // e.g., MCQ question id or callout index

  // SM-2 algorithm state
  easeFactor      Float     @default(2.5)
  intervalDays    Int       @default(0)
  repetitionCount Int       @default(0)
  
  // Scheduling
  dueDate         DateTime  @default(now())
  lastReviewedAt  DateTime?
  
  // Stats
  totalReviews    Int       @default(0)
  correctReviews  Int       @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId, sourceType, sourceId])
  @@index([userId, dueDate])
  @@index([lessonId])
}

enum SRSourceType {
  MCQ
  CALLOUT
  GLOSSARY
}

model UserSRSession {
  id              String    @id @default(cuid())
  userId          String
  sessionDate     DateTime  @default(now())
  cardsReviewed   Int       @default(0)
  cardsCorrect    Int       @default(0)
  timeSpentSeconds Int      @default(0)
  completed       Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  
  @@unique([userId, sessionDate])
  @@index([userId])
}

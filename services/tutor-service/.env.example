# AI Tutor Service Environment Variables
NODE_ENV=development
PORT=3015
LOG_LEVEL=info

# Database (isolated app_tutor schema)
TUTOR_DATABASE_URL=postgres://grahvani:PASSWORD@localhost:5432/grahvani?schema=app_tutor

# Cache / events / queues
TUTOR_REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
INTERNAL_SERVICE_KEY=your-internal-service-key

# External services
ADMIN_SERVICE_URL=http://localhost:3003
LEARNING_SERVICE_URL=http://localhost:3013
KNOWLEDGE_SERVICE_URL=http://localhost:3017
USER_SERVICE_URL=http://localhost:3002

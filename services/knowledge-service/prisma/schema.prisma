generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("KNOWLEDGE_DATABASE_URL")
  directUrl = env("KNOWLEDGE_DIRECT_URL")
  schemas   = ["app_knowledge"]
}

model KnowledgeEntry {
  id           String   @id @default(uuid()) @db.Uuid
  termKey      String   @unique @map("term_key") @db.VarChar(100)
  domain       String   @db.VarChar(30)
  category     String   @db.VarChar(50)
  title        String   @db.VarChar(200)
  sanskrit     String?  @db.VarChar(100)
  summary      String
  description  String
  howToRead    String?  @map("how_to_read")
  significance String?
  examples     Json     @default("[]")
  relatedTerms String[] @default([]) @map("related_terms") @db.VarChar(100)
  tags         String[] @default([]) @db.VarChar(50)
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([domain])
  @@index([category])
  @@index([tags], type: Gin)
  @@index([termKey])
  @@map("knowledge_entries")
  @@schema("app_knowledge")
}
